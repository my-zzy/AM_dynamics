<mujoco model="grasp_scene">
    <!--
    ===== Grasp Demo Scene =====
    Robot base hovers at z = 1.5 m (PID setpoint).

    Gripper geometry reference (all metres):
      Finger open inner gap  : 0.036 m   (2 × (0.026 − 0.008))
      Finger closed inner gap: ~0.004 m  (after 0.024 m slide travel)

    Graspable box (body "box"):
      Half-extents : 0.013 (x) × 0.013 (y) × 0.025 (z)
      Full size    : 0.026 m × 0.026 m × 0.050 m
      Fits in open gap with ~5 mm clearance per side in y.

    Box rests on a pedestal (top surface z = 1.10 m) placed at x = 0.40 m.
    With joint1 ≈ −0.5 rad and joint2 ≈ 0.8 rad the gripper centre reaches
    approximately (0.40, 0, 1.10) from a 1.5 m hover.
    -->

    <compiler angle="radian" coordinate="local"/>
    <option gravity="0 0 -9.81" timestep="0.002"/>

    <visual>
        <headlight ambient="0.2 0.2 0.2" diffuse="0.4 0.4 0.4" specular="0.0 0.0 0.0"/>
        <quality shadowsize="8192"/>
        <map znear="0.005" zfar="100"/>
        <rgba haze="0.15 0.25 0.35 1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="1024" height="1024"
                 rgb1="0.45 0.45 0.45" rgb2="0.65 0.65 0.65"/>
        <material name="grid_mat" texture="grid" texrepeat="5 5" texuniform="true"
                  reflectance="0.05"/>
        <texture name="sky" type="skybox" builtin="gradient"
                 rgb1="0.75 0.88 1.0" rgb2="0.08 0.18 0.45" width="512" height="512"/>

        <!-- Box material: bright red so it is easy to spot -->
        <material name="box_mat" rgba="0.85 0.15 0.15 1" reflectance="0.1"/>
        <!-- Pedestal material: dark wood-ish -->
        <material name="pedestal_mat" rgba="0.45 0.30 0.18 1" reflectance="0.05"/>
    </asset>

    <default>
        <joint damping="0.02"/>
        <geom contype="1" conaffinity="1"/>
        <default class="visual">
            <geom contype="0" conaffinity="0" mass="0"/>
        </default>
    </default>

    <worldbody>

        <!-- Ground -->
        <geom name="ground" type="plane" size="30 30 0.1" material="grid_mat"/>

        <!-- Cameras -->
        <camera name="track"  mode="trackcom" pos="3 -3 2"   xyaxes="1 1 0 -0.4 0.4 1"/>
        <camera name="side"   mode="trackcom" pos="0 -5 1.5" xyaxes="1 0 0 0 0.3 1"/>
        <camera name="fixed"  pos="4 4 3"                    xyaxes="-1 1 0 -0.5 -0.5 1"/>
        <!-- Close-up on the pedestal / box area -->
        <camera name="grasp_cam" pos="0.4 -0.6 1.3" xyaxes="1 0 0 0 0.6 1"/>

        <light name="main_light" pos="0 0 5" dir="0 0 -1"
               diffuse="0.8 0.8 0.8" specular="0.5 0.5 0.5" ambient="0.2 0.2 0.2"
               directional="true" castshadow="true"/>

        <!-- ===== Pedestal (fixed, no joint) ===== -->
        <!--   Cylinder column: radius 0.04 m, half-height 0.55 m → top at z = 1.10 m -->
        <body name="pedestal" pos="0.40 0 0">
            <geom name="pedestal_col"  type="cylinder" pos="0 0 0.55"
                  size="0.04 0.55"  material="pedestal_mat"/>
            <!-- Flat top plate -->
            <geom name="pedestal_top"  type="box"      pos="0 0 1.10"
                  size="0.08 0.08 0.005" material="pedestal_mat"/>
        </body>

        <!-- ===== Graspable box (free body) ===== -->
        <!--
            Box half-extents : 0.013 × 0.013 × 0.025
            Centre placed 0.025 m above the pedestal top surface → z = 1.125 m
            The box will rest on the plate once the simulation starts.
            High friction so it does not slide off the pedestal.
        -->
        <body name="box" pos="0.40 0 1.125">
            <joint name="box_free" type="free"/>
            <inertial pos="0 0 0" mass="0.05"
                      diaginertia="0.000014 0.000014 0.000014"/>
            <geom name="box_geom" type="box" size="0.013 0.013 0.025"
                  material="box_mat"
                  friction="1.5 0.1 0.005"
                  condim="4" solimp="0.95 0.99 0.001" solref="0.02 1"/>
        </body>

        <!-- ===== Quadrotor + Arm (from am_robot.xml, embedded) ===== -->
        <body name="base" pos="0 0 1.5">
            <joint name="free_joint" type="free"/>
            <inertial pos="0 0 0" mass="1.5" diaginertia="0.008 0.008 0.015"/>

            <!-- Main body -->
            <geom name="base_body" type="box" size="0.1 0.1 0.03" rgba="0.2 0.2 0.8 1"
                  contype="1" conaffinity="1" mass="0"/>

            <!-- X arms (visual) -->
            <geom type="capsule" fromto="0 0 0  0.15  0.15 0" size="0.01" class="visual"/>
            <geom type="capsule" fromto="0 0 0 -0.15  0.15 0" size="0.01" class="visual"/>
            <geom type="capsule" fromto="0 0 0 -0.15 -0.15 0" size="0.01" class="visual"/>
            <geom type="capsule" fromto="0 0 0  0.15 -0.15 0" size="0.01" class="visual"/>

            <!-- Propellers (visual) -->
            <geom type="cylinder" pos=" 0.15  0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>
            <geom type="cylinder" pos="-0.15  0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>
            <geom type="cylinder" pos="-0.15 -0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>
            <geom type="cylinder" pos=" 0.15 -0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>

            <!-- Landing legs (visual) -->
            <geom type="capsule" fromto=" 0.08  0.08 -0.03  0.08  0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <geom type="capsule" fromto="-0.08  0.08 -0.03 -0.08  0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <geom type="capsule" fromto="-0.08 -0.08 -0.03 -0.08 -0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <geom type="capsule" fromto=" 0.08 -0.08 -0.03  0.08 -0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <!-- Landing feet (contact) -->
            <geom type="sphere" pos=" 0.08  0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>
            <geom type="sphere" pos="-0.08  0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>
            <geom type="sphere" pos="-0.08 -0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>
            <geom type="sphere" pos=" 0.08 -0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>

            <site name="platform_site" pos="0 0 0" size="0.01"/>

            <!-- ===== Robot Arm ===== -->
            <body name="link1" pos="0 0 -0.05">
                <joint name="joint1" type="hinge" axis="0 1 0" damping="0.02"/>
                <inertial pos="0 0 -0.06" mass="0.15" diaginertia="0.0002 0.0002 0.00005"/>
                <geom name="link1_geom" type="capsule" fromto="0 0 0 0 0 -0.12"
                      size="0.015" rgba="0.8 0.2 0.2 1" mass="0"/>

                <body name="link2" pos="0 0 -0.12">
                    <joint name="joint2" type="hinge" axis="0 1 0" damping="0.02"/>
                    <inertial pos="0.08 0 0" mass="0.12" diaginertia="0.00015 0.00015 0.00003"/>
                    <geom name="link2_geom" type="capsule" fromto="0 0 0 0.16 0 0"
                          size="0.012" rgba="0.2 0.8 0.2 1" mass="0"/>

                    <!-- ===== Gripper ===== -->
                    <body name="ee" pos="0.16 0 0">
                        <inertial pos="0 0 0" mass="0.05"
                                  diaginertia="0.00005 0.00008 0.00008"/>
                        <geom name="palm_geom" type="box" size="0.02 0.032 0.015"
                              rgba="0.25 0.25 0.25 1" friction="1.0 0.05 0.005"/>

                        <body name="finger_left" pos="0.02 0.026 0">
                            <joint name="gripper_left_joint" type="slide" axis="0 1 0"
                                   range="-0.024 0" damping="2.0"/>
                            <inertial pos="0.028 0 0" mass="0.025"
                                      diaginertia="0.000010 0.000015 0.000015"/>
                            <geom name="finger_left_geom" type="capsule"
                                  fromto="0 0 0 0.058 0 0" size="0.008"
                                  rgba="0.75 0.38 0.1 1" friction="1.8 0.12 0.01"
                                  condim="4" solimp="0.9 0.95 0.001" solref="0.02 1"/>
                        </body>

                        <body name="finger_right" pos="0.02 -0.026 0">
                            <joint name="gripper_right_joint" type="slide" axis="0 1 0"
                                   range="0 0.024" damping="2.0"/>
                            <inertial pos="0.028 0 0" mass="0.025"
                                      diaginertia="0.000010 0.000015 0.000015"/>
                            <geom name="finger_right_geom" type="capsule"
                                  fromto="0 0 0 0.058 0 0" size="0.008"
                                  rgba="0.75 0.38 0.1 1" friction="1.8 0.12 0.01"
                                  condim="4" solimp="0.9 0.95 0.001" solref="0.02 1"/>
                        </body>

                        <site name="end_effector" pos="0.078 0 0" size="0.008"
                              rgba="0 0 0 0." type="sphere"/>
                    </body>
                </body>
            </body>

        </body>

    </worldbody>

    <!-- ctrl indices:
         0  joint1_torque    arm shoulder    [−5, 5] N·m
         1  joint2_torque    arm elbow       [−5, 5] N·m
         2  gripper_left     slide +y→close  [−20, 0] N
         3  gripper_right    slide −y→close  [ 0, 20] N
         (base force/torque applied via xfrc_applied, not actuators)
    -->
    <actuator>
        <motor name="joint1_torque"  joint="joint1"              gear="1" ctrllimited="true" ctrlrange="-5 5"/>
        <motor name="joint2_torque"  joint="joint2"              gear="1" ctrllimited="true" ctrlrange="-5 5"/>
        <motor name="gripper_left"   joint="gripper_left_joint"  gear="1" ctrllimited="true" ctrlrange="-20 0"/>
        <motor name="gripper_right"  joint="gripper_right_joint" gear="1" ctrllimited="true" ctrlrange="0 20"/>
    </actuator>

    <sensor>
        <!-- Joint position sensors -->
        <jointpos name="joint1_pos"        joint="joint1"/>
        <jointpos name="joint2_pos"        joint="joint2"/>
        <!-- <jointpos name="gripper_left_pos"  joint="gripper_left_joint"/>
        <jointpos name="gripper_right_pos" joint="gripper_right_joint"/> -->
        <!-- Joint velocity sensors -->
        <!-- <jointvel name="joint1_vel"        joint="joint1"/>
        <jointvel name="joint2_vel"        joint="joint2"/>
        <jointvel name="gripper_left_vel"  joint="gripper_left_joint"/>
        <jointvel name="gripper_right_vel" joint="gripper_right_joint"/> -->
        <!-- Platform (base) position via site -->
        <!-- <framepos  name="platform_pos"  objtype="site" objname="platform_site"/>
        <framequat name="platform_quat" objtype="site" objname="platform_site"/> -->
    </sensor>

</mujoco>
