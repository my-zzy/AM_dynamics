<mujoco model="am_scene">

    <compiler angle="radian" coordinate="local"/>
    <option gravity="0 0 -9.81" timestep="0.002"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3"/>
        <quality shadowsize="4096"/>
        <map znear="0.01"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1="0.4 0.4 0.4" rgb2="0.5 0.5 0.5"/>
        <material name="grid_mat" texture="grid" texrepeat="8 8" texuniform="true"
                  reflectance="0.1"/>
        <!-- <texture name="sky" type="skybox" builtin="gradient"
                 rgb1="0.6 0.8 1.0" rgb2="0.15 0.3 0.6" width="512" height="512"/> -->
    </asset>

    <default>
        <joint damping="0.02"/>
        <geom contype="1" conaffinity="1"/>
        <default class="visual">
            <geom contype="0" conaffinity="0" mass="0"/>
        </default>
    </default>

    <worldbody>

        <!-- Ground -->
        <geom name="ground" type="plane" size="5 5 0.1" rgba="0.9 0.9 0.9 1"/>

        <!-- Camera -->
        <camera name="track" mode="trackcom" pos="1.5 -1.5 1.5" xyaxes="1 1 0 -0.5 0.5 1"/>
        <camera name="fixed" pos="1.5 1.5 1.0" xyaxes="-1 1 0 -0.5 -0.5 1"/>

        <!-- Lights -->
        <!-- <light pos="0 -2 3" dir="0 0.3 -1" diffuse="0.8 0.8 0.8" castshadow="true"/> -->
        <light pos="0 0 2"/>

        <!-- Target marker -->
        <!-- <site name="target" pos="0 0 0.25" size="0.03" rgba="0 1 0 0.5" type="sphere"/> -->

        <!-- ===== Quadrotor Base ===== -->
        <body name="base" pos="0 0 0.25">
            <joint name="free_joint" type="free"/>
            <inertial pos="0 0 0" mass="1.5" diaginertia="0.008 0.008 0.015"/>

            <!-- Main body -->
            <geom name="base_body" type="box" size="0.1 0.1 0.03" rgba="0.2 0.2 0.8 1"
                  contype="1" conaffinity="1" mass="0"/>

            <!-- X configuration arms (visual, no mass) -->
            <geom type="capsule" fromto="0 0 0 0.15 0.15 0" size="0.01" class="visual"/>
            <geom type="capsule" fromto="0 0 0 -0.15 0.15 0" size="0.01" class="visual"/>
            <geom type="capsule" fromto="0 0 0 -0.15 -0.15 0" size="0.01" class="visual"/>
            <geom type="capsule" fromto="0 0 0 0.15 -0.15 0" size="0.01" class="visual"/>

            <!-- Propellers (visual) -->
            <geom type="cylinder" pos="0.15 0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>
            <geom type="cylinder" pos="-0.15 0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>
            <geom type="cylinder" pos="-0.15 -0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>
            <geom type="cylinder" pos="0.15 -0.15 0" size="0.05 0.005" rgba="0.1 0.1 0.1 0.7" class="visual"/>

            <!-- Landing legs (visual, no mass) -->
            <geom type="capsule" fromto="0.08 0.08 -0.03 0.08 0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <geom type="capsule" fromto="-0.08 0.08 -0.03 -0.08 0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <geom type="capsule" fromto="-0.08 -0.08 -0.03 -0.08 -0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <geom type="capsule" fromto="0.08 -0.08 -0.03 0.08 -0.08 -0.20" size="0.008" rgba="0.3 0.3 0.3 1" class="visual"/>
            <!-- Landing feet (contact with ground) -->
            <geom type="sphere" pos="0.08 0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>
            <geom type="sphere" pos="-0.08 0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>
            <geom type="sphere" pos="-0.08 -0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>
            <geom type="sphere" pos="0.08 -0.08 -0.20" size="0.012" rgba="0.3 0.3 0.3 1" mass="0"/>

            <!-- Platform site for force application -->
            <site name="platform_site" pos="0 0 0" size="0.01"/>

            <!-- ===== Robot Arm ===== -->
            <body name="link1" pos="0 0 -0.05">
                <joint name="joint1" type="hinge" axis="0 1 0" damping="0.02"/>
                <inertial pos="0 0 -0.06" mass="0.15" diaginertia="0.0002 0.0002 0.00005"/>

                <!-- Vertical link going down -->
                <geom name="link1_geom" type="capsule" fromto="0 0 0 0 0 -0.12"
                      size="0.015" rgba="0.8 0.2 0.2 1" mass="0"/>

                <body name="link2" pos="0 0 -0.12">
                    <joint name="joint2" type="hinge" axis="0 1 0" damping="0.02"/>
                    <inertial pos="0.08 0 0" mass="0.12" diaginertia="0.00015 0.00015 0.00003"/>

                    <!-- Horizontal link (90 deg bend) -->
                    <geom name="link2_geom" type="capsule" fromto="0 0 0 0.16 0 0"
                          size="0.012" rgba="0.2 0.8 0.2 1" mass="0"/>

                    <!-- End effector -->
                    <body name="ee" pos="0.16 0 0">
                        <geom name="ee_geom" type="sphere" size="0.025"
                              rgba="0.9 0.9 0.1 1" mass="0.1"/>
                        <site name="end_effector" pos="0 0 0" size="0.015"
                              rgba="1 0 0 0.8" type="sphere"/>
                    </body>
                </body>
            </body>

        </body>

    </worldbody>

    <!-- Actuators: joint motors; platform force/torque via xfrc_applied -->
    <actuator>
        <motor name="joint1_torque" joint="joint1" gear="1" ctrllimited="true" ctrlrange="-5 5"/>
        <motor name="joint2_torque" joint="joint2" gear="1" ctrllimited="true" ctrlrange="-5 5"/>
    </actuator>

</mujoco>